# AI 后端环境变量示例
# 复制为 .env 修改后使用: cp .env.example .env

# ==================== 服务 ====================
HOST=0.0.0.0
PORT=8080
DEBUG=false

# ==================== 模型 ====================
MODEL_PATH=./model/best.pt
MODEL_IMGSZ=640
MODEL_CONF=0.35
PRELOAD_MODEL=true
USE_COCO_MAPPING=false

# ==================== 推理 ====================
INFERENCE_FPS=5
MAX_VIDEO_SIZE_MB=500

# ==================== 行为规则(bbox) ====================
IOU_THRESHOLD=0.10
MIN_EVENT_DURATION_SEC=3.0
MAX_EVENT_GAP_SEC=2.0

# ==================== 事件推送(告诉本服务往哪推事件) ====================
CALLBACK_URL=
CALLBACK_AUTH_TOKEN=
CALLBACK_MAX_RETRIES=3
CALLBACK_TIMEOUT_SEC=5

# ==================== LLM 视觉复核(第 3 层级联)====================
# provider: qwen(通义)/ zhipu(智谱)
LLM_PROVIDER=qwen

# API Key(**必填**,不填则 LLM 层降级到 pass-through)
# 通义:https://dashscope.aliyun.com/apiKey
# 智谱:https://open.bigmodel.cn/usercenter/apikeys
LLM_API_KEY=

# 兼容别名(如果只有 DashScope 也认)
# DASHSCOPE_API_KEY=

# 高级(留空自动按 provider 取默认)
LLM_BASE_URL=
LLM_MODEL=

# 请求超时(秒)
LLM_TIMEOUT=30
