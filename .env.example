# AI 后端环境变量示例
# 复制为 .env 修改后使用: cp .env.example .env

# ==================== 服务 ====================
HOST=0.0.0.0
PORT=8080
DEBUG=false

# ==================== 模型 ====================
# 训练好的模型路径。首次可用 yolov8n.pt (COCO) 占位测试
MODEL_PATH=./model/best.pt
MODEL_IMGSZ=640
MODEL_CONF=0.35
PRELOAD_MODEL=true

# 占位模型模式(model/best.pt 不是你训的时开启)
# true = 用 COCO 里的 cat=15 dog=16 bowl=45 兼容
USE_COCO_MAPPING=false

# ==================== 推理 ====================
INFERENCE_FPS=5
MAX_VIDEO_SIZE_MB=500

# ==================== 行为规则 ====================
IOU_THRESHOLD=0.10
MIN_EVENT_DURATION_SEC=3.0
MAX_EVENT_GAP_SEC=2.0

# ==================== 事件推送(告诉本服务往哪推事件) ====================
# 甲方后端接收事件的 URL。留空 = 不推送,只写本地日志
CALLBACK_URL=
CALLBACK_AUTH_TOKEN=
CALLBACK_MAX_RETRIES=3
CALLBACK_TIMEOUT_SEC=5
