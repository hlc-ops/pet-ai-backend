# ==================== 模型权重 ====================
# 为交付朋友一键 clone 就能用, 权重全部入库 (每个文件 <100MB, GitHub 允许)
# 顶层意外下载的其他 pt 权重排除
/best.pt
/best.onnx
/*.engine
/*.torchscript
!model/.gitkeep
# 训练可视化
!model/results.png
!model/confusion_matrix.png
!model/PR_curve.png
!model/F1_curve.png
!model/args.yaml

# ==================== 运行时数据(每台机器不同)====================
data/
!data/.gitkeep

# ==================== 日志 ====================
logs/
!logs/.gitkeep

# ==================== 上传缓存 ====================
uploads/
snapshots/
failed_events.jsonl

# ==================== Python 常规 ====================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
.python-version

# ==================== 虚拟环境 ====================
.venv/
venv/
env/
ENV/

# ==================== IDE ====================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ==================== 环境变量(含密钥)====================
.env
.env.local
.env.*.local

# ==================== 临时 ====================
*.tmp
*.bak
*.log
tmp/
temp/
pip_cache_d/
